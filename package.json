{
  "name": "blossom-api",
  "version": "1.0.0",
  "description": "Unified REST API for Pokémon and Digimon franchise data — Hexagonal Architecture + TypeScript",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/main.js",
    "test": "jest --coverage --forceExit",
    "test:unit": "jest --testPathPattern=tests/unit --coverage --forceExit",
    "test:integration": "jest --testPathPattern=tests/integration --forceExit",
    "lint": "tsc --noEmit"
  },
  "keywords": ["pokemon", "digimon", "rest-api", "hexagonal-architecture", "typescript"],
  "author": "Blossom API",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.28",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.2"
  }
}
